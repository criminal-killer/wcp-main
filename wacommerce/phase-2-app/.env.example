# Environment Variables
# Copy this to .env.local and fill in your values

# ============================================
# Clerk Authentication
# https://clerk.com → Create App → Get Keys
# ============================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding
CLERK_WEBHOOK_SECRET=whsec_...

# ============================================
# Turso Database
# https://turso.tech → Create Database → Get URL + Token
# ============================================
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=eyJ...

# ============================================
# WhatsApp / Meta
# https://developers.facebook.com → WhatsApp → Getting Started
# ============================================
WHATSAPP_VERIFY_TOKEN=your-random-string-here
WHATSAPP_APP_SECRET=your-meta-app-secret

# ============================================
# AI (WhatsApp Bot Intelligence)
# https://console.groq.com
# ============================================
GROQ_API_KEY=gsk_...
GOOGLE_GEMINI_API_KEY=AI...

# ============================================
# Payments — YOUR SaaS Subscription Accounts
# ============================================
# Paystack: https://paystack.com → Settings → API Keys
PAYSTACK_SECRET_KEY=sk_live_...
PAYSTACK_PUBLIC_KEY=pk_live_...
PAYSTACK_WEBHOOK_SECRET=your-paystack-webhook-secret

# Stripe: https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...

# PayPal: https://developer.paypal.com
PAYPAL_CLIENT_ID=...
PAYPAL_CLIENT_SECRET=...

# ============================================
# Cache: Upstash Redis
# https://console.upstash.com → Create Database
# ============================================
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=AX...

# ============================================
# Email: Resend
# https://resend.com → API Keys
# ============================================
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@sella.io

# ============================================
# File Storage: Vercel Blob
# Auto-configured on Vercel deployment
# ============================================
BLOB_READ_WRITE_TOKEN=vercel_blob_...

# ============================================
# Security
# ============================================
# 32-character random string for AES-256 encryption
ENCRYPTION_KEY=your-32-character-random-string!!

# Your Clerk User ID to access /admin routes
ADMIN_USER_ID=user_...

# Vercel Cron Security
CRON_SECRET=your-cron-secret

# ============================================
# App Config
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SELLA
