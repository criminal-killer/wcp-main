# Environment Variables for Chatevo (WhatsApp Commerce Platform)
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ============================================
# Clerk Authentication
# https://clerk.com → Create App → Get Keys
# ============================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding
CLERK_WEBHOOK_SECRET=whsec_...

# ============================================
# Turso Database
# https://turso.tech → Create Database → Get URL + Token
# ROTATE THESE KEYS — never hardcode in source files
# ============================================
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=eyJ...

# ============================================
# WhatsApp / Meta
# https://developers.facebook.com → WhatsApp → Getting Started
# ============================================
WHATSAPP_VERIFY_TOKEN=your-unique-random-string-here
WHATSAPP_APP_SECRET=your-meta-app-secret

# ============================================
# AI (WhatsApp Bot Intelligence)
# ============================================
# Groq (Default Chatevo AI — free tier available)
# https://console.groq.com
GROQ_API_KEY=gsk_...

# Google Gemini (Pro/Elite plans)
# https://aistudio.google.com/app/apikey
GOOGLE_GEMINI_API_KEY=AI...

# ============================================
# SaaS Subscription Payments — Chatevo Platform Accounts
# These are YOUR (operator) keys, NOT per-merchant.
# ============================================

# Paystack (Africa / local cards)
# https://paystack.com → Settings → API Keys
PAYSTACK_SECRET_KEY=sk_live_...
PAYSTACK_PUBLIC_KEY=pk_live_...
PAYSTACK_WEBHOOK_SECRET=your-paystack-webhook-secret
# Paystack subscription plan codes (create plans in Paystack dashboard)
PAYSTACK_STARTER_PLAN_CODE=PLN_...
PAYSTACK_PRO_PLAN_CODE=PLN_...
PAYSTACK_ELITE_PLAN_CODE=PLN_...

# Stripe (Global)
# https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe recurring price IDs (create products in Stripe dashboard)
# If not set, ad-hoc prices will be created automatically
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ELITE_PRICE_ID=price_...

# ============================================
# Cache: Upstash Redis
# https://console.upstash.com → Create Database
# ============================================
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=AX...

# ============================================
# Email: Resend
# https://resend.com → API Keys
# Used for OTP verification, welcome emails, and notifications
# ============================================
RESEND_API_KEY=re_...
EMAIL_FROM_DOMAIN=chatevo.io

# ============================================
# File Storage: Vercel Blob
# Auto-configured on Vercel deployment
# ============================================
BLOB_READ_WRITE_TOKEN=vercel_blob_...

# ============================================
# Security — ROTATE BEFORE GOING LIVE
# ============================================

# 32-character random string for AES-256 encryption of API keys
# Generate: openssl rand -hex 16
ENCRYPTION_KEY=your-32-character-random-string!!

# Secret for HMAC-signed OTP tokens (settings security verification)
# Generate: openssl rand -base64 32
OTP_HMAC_SECRET=your-otp-hmac-secret-min-32-chars

# Your Clerk User ID to access /admin routes
ADMIN_USER_ID=user_...

# Vercel Cron job protection secret
CRON_SECRET=your-cron-secret

# ============================================
# App Config
# ============================================
NEXT_PUBLIC_APP_URL=https://app.chatevo.io
NEXT_PUBLIC_APP_NAME=Chatevo
