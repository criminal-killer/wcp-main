{
  "name": "chatevo-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Chatevo WhatsApp Commerce Platform — Monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:merchant":   "npm run dev   --workspace=apps/merchant",
    "dev:admin":      "npm run dev   --workspace=apps/admin",
    "build:merchant": "npm run build --workspace=apps/merchant",
    "build:admin":    "npm run build --workspace=apps/admin",
    "typecheck":      "npm run typecheck --workspaces --if-present",
    "lint":           "npm run lint --workspaces --if-present",
    "sync-env":       "node scripts/sync-env.mjs",
    "db:push":        "npm run db:push --workspace=apps/merchant",
    "db:studio":      "npm run db:studio --workspace=apps/merchant"
  },
  "devDependencies": {
    "typescript": "5.4.5",
    "zod": "^3.23.8"
  },
  "overrides": {
    "typescript": "5.4.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm":  ">=8.0.0"
  }
}
